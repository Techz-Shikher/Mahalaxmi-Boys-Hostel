<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f7fa">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/gradient_orange"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:text="🍽️ Book Food"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#fff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/selectedDateLabel"
            android:text="Booking for: Today"
            android:textSize="14sp"
            android:textColor="#666"
            android:textStyle="italic"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Select Your Meal"
            android:textSize="16sp"
            android:textColor="#333"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Spinner
            android:id="@+id/mealSpinner"
            android:prompt="@string/meal_prompt"
            android:layout_marginBottom="32dp"
            android:background="@drawable/input_background"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <TextView
            android:id="@+id/mealTypeLabel"
            android:text="🥐 Breakfast selected"
            android:textSize="14sp"
            android:textColor="#5b6ef5"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/bookBtn"
            android:text="Confirm Booking"
            android:textSize="16sp"
            android:textColor="#fff"
            android:textStyle="bold"
            android:padding="16dp"
            android:background="@drawable/gradient_orange"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

    </LinearLayout>

</LinearLayout>
